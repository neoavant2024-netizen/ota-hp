---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import { news } from '../data/news';
import { salePhoto } from '../lib/photos';

const desc = 'ホワイト急便太田のお知らせ・セール情報。季節ごとのクリーニングセールや営業に関するご案内を掲載しています。群馬・埼玉北部のクリーニング。';

// 最新数件だけ表示し、それ以前は「過去のお知らせ」として折りたたむ
// （更新のたびに積み重なってもページが際限なく伸びないようにするため）
const RECENT = 5;
const recent = news.slice(0, RECENT);
const older = news.slice(RECENT);
const firstSale = news.find((x) => x.category === 'セール');
const imgFor = (n: typeof news[number]) => n.image ?? (n === firstSale ? salePhoto() : undefined);
---
<Base title="お知らせ・セール" description={desc} current="news">
<main>
  <PageHero
    crumb="お知らせ・セール"
    kana="NEWS"
    title="お知らせ・セール情報"
    sub="季節ごとのクリーニングセールや、営業に関するご案内を掲載しています。セール内容は店舗により異なる場合がありますので、詳しくはお近くの店舗へお問い合わせください。"
    mascot="dogpeek"
    motion="peek"
  />

  <section class="band" style="padding-top:clamp(40px,7vw,90px)">
    <div class="wrap" style="max-width:900px">
      {news.length === 0 ? (
        <p class="news-empty">現在、お知らせはありません。</p>
      ) : (
        <div style="display:flex;flex-direction:column;gap:18px">
          {recent.map((n) => (
            <article class="sale-card reveal">
              <div class="meta">
                <span class="news-date">{n.date}</span>
                <span class:list={['news-tag', n.category === 'お知らせ' && 'info']}>{n.category}</span>
              </div>
              <h3>{n.title}</h3>
              {n.body && <p>{n.body}</p>}
              {imgFor(n) && (
                <a class="flyer-shot" href={imgFor(n)} target="_blank" rel="noopener">
                  <img src={imgFor(n)} alt={n.imageAlt ?? n.title} loading="lazy" />
                </a>
              )}
              {n.link && (
                <p style="margin-top:14px">
                  <a class="btn btn-ghost" href={n.link} target="_blank" rel="noopener">詳しく見る<span class="arw">→</span></a>
                </p>
              )}
            </article>
          ))}
        </div>
      )}

      {older.length > 0 && (
        <details class="news-archive">
          <summary>過去のお知らせを見る（{older.length}件）</summary>
          <div style="display:flex;flex-direction:column;gap:18px;margin-top:18px">
            {older.map((n) => (
              <article class="sale-card">
                <div class="meta">
                  <span class="news-date">{n.date}</span>
                  <span class:list={['news-tag', n.category === 'お知らせ' && 'info']}>{n.category}</span>
                </div>
                <h3>{n.title}</h3>
                {n.body && <p>{n.body}</p>}
                {imgFor(n) && (
                  <a class="flyer-shot" href={imgFor(n)} target="_blank" rel="noopener">
                    <img src={imgFor(n)} alt={n.imageAlt ?? n.title} loading="lazy" />
                  </a>
                )}
                {n.link && (
                  <p style="margin-top:14px">
                    <a class="btn btn-ghost" href={n.link} target="_blank" rel="noopener">詳しく見る<span class="arw">→</span></a>
                  </p>
                )}
              </article>
            ))}
          </div>
        </details>
      )}

      <p class="note" style="margin-top:26px;font-size:.82rem;color:var(--ink-faint)">※ セールの対象品目・価格・実施期間は店舗により異なります。詳しくはお近くの店舗、または本部（0276-52-7027）へお問い合わせください。</p>
    </div>
  </section>

  <CtaBand heading="セールの詳細はお近くの店舗へ" text="対象品目や価格は店舗によって異なります。お気軽にお問い合わせください。" />
</main>
</Base>
