---
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';
import { areas, shopSearchUrl, SHOP_SEARCH } from '../../data/stores';
import { factoryPhoto } from '../../lib/photos';

export function getStaticPaths() {
  return areas.map((a) => ({ params: { area: a.key }, props: { area: a } }));
}

const { area } = Astro.props;
// public/images/factory/{エリアkey}.jpg があれば自動的に使う（コード編集不要）
const photo = area.factory ? (area.factory.photo ?? factoryPhoto(area.key)) : undefined;
const cityNames = area.cities.map((c: { n: string }) => c.n).join('・');
const desc = `${area.name}（${cityNames}）のホワイト急便太田 店舗一覧。${area.factory ? `${area.factory.name}が担当し、` : ''}営業店${area.shops.length}店舗の営業時間・住所・電話をご案内します。`;

// 構造化データ（各営業店を LocalBusiness として出力）
const shopsLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${area.name} 店舗一覧`,
  itemListElement: area.shops.map((s: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'DryCleaningOrLaundry',
      name: `ホワイト急便 ${s.name}`,
      address: { '@type': 'PostalAddress', streetAddress: s.address, addressCountry: 'JP' },
      telephone: s.tel,
      openingHours: s.hours,
      parentOrganization: { '@type': 'Organization', name: '株式会社ホワイト急便太田' },
    },
  })),
};
---
<Base title={`${area.name}の店舗・工場`} description={desc} current="stores">
<main>
  <!-- エリアのヒーロー -->
  <section class="page-hero">
    <span class="kana" aria-hidden="true">{area.code}</span>
    <div class="wrap">
      <p class="crumb"><a href="/">HOME</a> ／ <a href="/stores/">店舗・工場案内</a> ／ {area.name}</p>
      <h1 class="reveal">{area.name}</h1>
      <p class="sub reveal">{cityNames}</p>
      <div class="city-links reveal" style="margin-top:18px">
        {area.cities.map((c: { n: string; pre?: string }) => (
          c.pre
            ? <a class="ext" href={shopSearchUrl(c.pre, c.n)} target="_blank" rel="noopener">{c.n}</a>
            : <span style="font-size:.8rem;font-weight:600;color:var(--ink-soft);padding:.36em .8em">{c.n}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- 担当工場 -->
  {area.factory && (
    <section class="band" style="padding-top:clamp(40px,6vw,72px);padding-bottom:clamp(32px,5vw,56px)">
      <div class="wrap">
        <div class="sec-head reveal">
          <span class="eyebrow">担当工場</span>
          <h2>{area.factory.name}</h2>
        </div>
        <div class="factory-detail" style="margin-top:36px">
          <div class="reveal">
            {photo ? (
              <img src={photo} alt={`${area.factory.name}の外観`} loading="lazy"
                   style="width:100%;aspect-ratio:3/2;object-fit:cover;border-radius:16px" />
            ) : (
              <div class="photo-frame" aria-hidden="true">
                <div class="pf-in">
                  <span class="pf-ic">📷</span>
                  <span class="pf-t">写真準備中</span>
                  <span class="pf-s">{area.key}.jpg を置くと表示されます</span>
                </div>
              </div>
            )}
          </div>
          <div class="reveal">
            <p class="lead-block" style="margin-top:0">{area.factory.intro}</p>
            <dl class="info-table" style="margin-top:24px">
              {area.factory.note && <div><dt>設備</dt><dd>{area.factory.note}</dd></div>}
              <div><dt>住所</dt><dd>{area.factory.address}</dd></div>
              <div><dt>電話</dt><dd><a href={`tel:${area.factory.tel}`} style="font-family:var(--lat);font-weight:700;color:var(--brand-deep)">{area.factory.tel}</a></dd></div>
              <div><dt>営業時間</dt><dd>{area.factory.hours}</dd></div>
            </dl>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- 営業店一覧 -->
  <section class="band" style="background:linear-gradient(180deg,#fff,var(--ground));padding-top:clamp(40px,6vw,72px)">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">営業店一覧</span>
        <h2>{area.name}の店舗</h2>
        {area.shops.length > 0
          ? <p>取次店・スーパー内カウンター・ショッピングセンターのテナントなど、{area.shops.length}店舗を展開しています。</p>
          : <p>このエリアの店舗一覧は準備中です。お近くの店舗はお電話または公式サイトの店舗検索でご確認ください。</p>}
      </div>

      {area.shops.length > 0 ? (
        <div class="table-scroll reveal">
          <table class="stores">
            <thead>
              <tr><th>営業店名</th><th>営業時間</th><th>住所</th><th>電話</th></tr>
            </thead>
            <tbody>
              {area.shops.map((s: any) => (
                <tr>
                  <td style="font-weight:700">{s.name}</td>
                  <td>
                    {s.hours}
                    {s.rest && <><br /><span style="color:var(--ink-faint);font-size:.92em">{s.rest}</span></>}
                    {s.closed && <><br /><span class="closed-tag">{s.closed}</span></>}
                  </td>
                  <td>{s.address}</td>
                  <td><a href={`tel:${s.tel}`}>{s.tel}</a></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="reveal" style="margin-top:28px">
          <a class="btn btn-primary" href={SHOP_SEARCH} target="_blank" rel="noopener">公式サイトの店舗検索で探す<span class="arw">→</span></a>
        </div>
      )}

      <p class="note reveal" style="margin-top:18px;font-size:.82rem;color:var(--ink-faint)">※ 営業時間・定休日は変更となる場合があります。おでかけ前にお電話でご確認いただくと確実です。</p>

      <div class="reveal" style="margin-top:30px">
        <a class="btn btn-ghost" href="/stores/">← 他のエリアを見る</a>
      </div>
    </div>
  </section>

  <CtaBand heading="お品物のご相談はお近くの店舗へ" text="セール情報や対応品目など、お気軽にお問い合わせください。" />
  <script type="application/ld+json" set:html={JSON.stringify(shopsLd)} />
</main>
</Base>
