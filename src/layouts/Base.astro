---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

const {
  title,
  description = '群馬・埼玉北部のクリーニングなら、創業50余年・従業員180名のホワイト急便太田。スーツや日常の衣類から、一押しのハイクラス仕上げ、法人・団体のユニフォーム・催事まで承ります。',
  current = '',
  ogType = 'website',
} = Astro.props;

const siteName = 'ホワイト急便 太田（株式会社ホワイト急便太田）';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://www.white-ota.co.jp').href;
const fullTitle = title ? `${title}｜${siteName}` : siteName;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'DryCleaningOrLaundry',
  name: '株式会社ホワイト急便太田',
  alternateName: 'ホワイト急便 太田',
  url: 'https://www.white-ota.co.jp/',
  telephone: '+81-276-52-7027',
  email: 'info@white-ota.co.jp',
  foundingDate: '1972',
  description,
  address: {
    '@type': 'PostalAddress',
    postalCode: '370-0426',
    addressRegion: '群馬県',
    addressLocality: '太田市',
    streetAddress: '世良田町283-1',
    addressCountry: 'JP',
  },
  areaServed: ['群馬県', '埼玉県北部', '栃木県足利市'],
  memberOf: { '@type': 'Organization', name: '日本さわやかグループ' },
  numberOfEmployees: { '@type': 'QuantitativeValue', value: 180 },
};
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <script is:inline>
    // モーションが許可されている時だけアニメの初期非表示を有効化（JS無効時は全表示のまま）
    if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.documentElement.classList.add('anim');
      // 保険：モーションJSが読み込まれなかった場合、一定時間後に全要素を表示する
      window.__revealFailsafe = setTimeout(function () {
        document.querySelectorAll('.reveal, .clip').forEach(function (e) { e.classList.add('in'); });
        document.querySelectorAll('[data-ln]').forEach(function (e) { e.classList.add('rise'); });
      }, 2600);
    }
  </script>
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" content="#C42576" />
  <meta name="format-detection" content="telephone=no" />

  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />

  {/* 本部サイト（www.white-ex.co.jp）と同じ Noto Sans JP。約物は YakuHanJP が担当（global.css で自社設置） */}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" />
  <link rel="preload" as="font" type="font/woff2" href="/fonts/YakuHanJP/YakuHanJP-Regular.woff2" crossorigin />
  <link rel="preload" as="font" type="font/woff2" href="/fonts/YakuHanJP/YakuHanJP-Bold.woff2" crossorigin />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <ClientRouter />
</head>
<body>
  <Header current={current} />
  <slot />
  <Footer />

  <script>
    import '../scripts/site.js';
  </script>
</body>
</html>
