---
const { current = '' } = Astro.props;
const nav = [
  { href: '/', label: 'ホーム', key: 'home' },
  { href: '/service/', label: 'サービス', key: 'service' },
  { href: '/premium/', label: 'プレミアム仕上げ', key: 'premium' },
  { href: '/corporate/', label: '法人・団体', key: 'corporate' },
  { href: '/stores/', label: '店舗・工場', key: 'stores' },
  { href: '/recruit/', label: '採用情報', key: 'recruit' },
  { href: '/guide/', label: 'Q&A', key: 'guide' },
  { href: '/contact/', label: 'お問い合わせ', key: 'contact' },
];
---
<header class="site-header" id="header">
  <a class="brand" href="/" aria-label="ホワイト急便 太田 トップ">
    <img class="brand-logo" src="/logo.svg" alt="ホワイト急便" width="493" height="393" />
    <span class="brand-name">太田<small>WHITE&nbsp;OTA&nbsp;SINCE&nbsp;1972</small></span>
  </a>
  <nav class="nav" id="nav" aria-label="グローバルナビゲーション">
    <button class="nav-close" id="navClose" aria-label="メニューを閉じる" type="button">×</button>
    {nav.map((n) => (
      <a href={n.href} aria-current={current === n.key ? 'page' : undefined}>{n.label}</a>
    ))}
  </nav>
  <div class="header-cta">
    <span class="tel"><small>本部受付 平日 8:00-17:00</small>0276-52-7027</span>
    <a class="btn btn-primary" href="/stores/">店舗を探す<span class="arw">→</span></a>
    <button class="nav-toggle" id="navToggle" aria-label="メニューを開く" aria-expanded="false" type="button"><span></span><span></span><span></span></button>
  </div>
</header>
