{
  // Cloudflare Workers（静的アセット配信）の設定
  // ビルドで生成される dist/ をそのまま配信します。Workerスクリプト(main)は不要です。
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ota-hp",
  "compatibility_date": "2026-07-17",
  "assets": {
    "directory": "./dist",
    // 存在しないURLは 404 ページを返す（静的サイトの標準的な挙動）
    "not_found_handling": "404-page"
  }
}
